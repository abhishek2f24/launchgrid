{
  "manifest_version": 3,
  "name": "LaunchGrid — Add to Store",
  "short_name": "LaunchGrid",
  "version": "2.0.0",
  "description": "See any product on Amazon, Flipkart, Meesho & more — add it to your LaunchGrid store in one click, with your margin.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://launchgrid.in/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.in/*",
        "https://amazon.in/*",
        "https://www.flipkart.com/*",
        "https://www.meesho.com/*",
        "https://meesho.com/*",
        "https://www.myntra.com/*",
        "https://www.nykaa.com/*",
        "https://www.ajio.com/*",
        "https://www.snapdeal.com/*",
        "https://www.glowroad.com/*",
        "https://www.indiamart.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LaunchGrid — Add to Store"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["auth-callback.html", "icons/icon48.png"],
      "matches": ["http://localhost:3000/*", "https://launchgrid.in/*"]
    }
  ]
}
