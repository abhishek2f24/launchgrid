{
  "expo": {
    "name": "LaunchGrid",
    "slug": "launchgrid",
    "version": "1.0.0",
    "scheme": "launchgrid",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1A18"
    },
    "ios": {
      "bundleIdentifier": "in.launchgrid.app",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "LaunchGrid uses the camera so you can photograph products and add them to your store.",
        "NSPhotoLibraryUsageDescription": "LaunchGrid accesses your photos so you can choose product images for your store.",
        "NSFaceIDUsageDescription": "Face ID keeps your business data locked to you on this device.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "in.launchgrid.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A1A18"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_CONTACTS",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#FF8A00"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "cameraPermission": "LaunchGrid uses the camera so you can photograph products and add them to your store.",
          "photosPermission": "LaunchGrid accesses your photos so you can choose product images for your store."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#FF8A00",
          "defaultChannel": "orders"
        }
      ],
      "expo-local-authentication"
    ],
    "extra": {
      "supabaseUrl": "SET_IN_EAS_OR_ENV",
      "supabaseAnonKey": "SET_IN_EAS_OR_ENV",
      "apiBaseUrl": "https://launchgrid.in",
      "privacyPolicyUrl": "https://launchgrid.in/legal/privacy",
      "termsUrl": "https://launchgrid.in/legal/terms"
    }
  }
}
